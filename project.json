          "method": "POST",
          "path": "/bookings",
          "auth": "X-User-Code header",
          "description": "Create booking"
        },
        {
          "method": "GET",
          "path": "/bookings/user/:user_code",
          "description": "Get user booking history"
        }
      ],
      "admin": [
        {
          "method": "POST",
          "path": "/admin/theaters",
          "auth": "X-Admin-Key header",
          "description": "Create theater"
        },
        {
          "method": "DELETE",
          "path": "/admin/theaters/:id",
          "auth": "X-Admin-Key header",
          "description": "Delete theater"
        }
      ]
    }
  },
